    const { error } = await supabase
        .from("catalog_suggestion_comments")
        .insert({
            suggestion_id: suggestionId,
            user_id: user.id,
            user_alias: alias,
            body: sanitized,
        });

    if (error) return { success: false, error: error.message };
    revalidatePath(`/catalog/suggestions/${suggestionId}`);
    return { success: true };
}

