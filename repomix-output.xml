 const { data: rawRecords } = await supabase
 .from("show_records")
 .select(
 'id, show_name, show_date, division, class_name,"placing", ribbon_color, judge_name, is_nan, notes, show_location, section_name, award_category, competition_level, show_date_text',
 )
 .eq("horse_id", horseId)
