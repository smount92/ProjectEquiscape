 <label htmlFor="edit-value" className="text-ink mb-1 block text-sm font-semibold">
 Estimated Current Value
 </label>
 <input
 id="edit-value"
 type="number"
 className="form-input"
 placeholder="0.00"
 min="0"
 step="0.01"
 value={estimatedValue}
 onChange={(e) => setEstimatedValue(e.target.value)}
 />
 </div>
