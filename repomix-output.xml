                    </div>
                    {group.description && (
                        <p style={{ marginTop: "var(--space-md)", lineHeight: 1.6 }}>{group.description}</p>
                    )}
                </div>

                {/* Content */}
                {group.isMember ? (
                    <GroupDetailClient
                        group={group}
                        initialPosts={posts}
                        channels={channels}
                        currentUserId={user.id}
                    />
                ) : (
                    <div className="empty-state" style={{ marginTop: "var(--space-xl)" }}>
                        <p>Join this group to see posts and participate.</p>
                    </div>
                )}
            </div>
        </div>
    );
}
