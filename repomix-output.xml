<file path=".github/workflows/ci.yml">
name: CI

on:
  push:
    branches: [main, quality-sprint-*]
  pull_request:
    branches: [main]

jobs:
  build-and-test:
    runs-on: ubuntu-latest
    timeout-minutes: 15

    strategy:
      matrix:
        node-version: [20]

    steps:
      - uses: actions/checkout@v4

      - name: Use Node.js ${{ matrix.node-version }}
        uses: actions/setup-node@v4
        with:
          node-version: ${{ matrix.node-version }}
          cache: 'npm'

      - name: Install dependencies
        run: npm ci

      - name: Lint check
        run: npx next lint --quiet
        continue-on-error: true  # Lint is advisory for now

      - name: Build
        run: npm run build
        env:
          NEXT_PUBLIC_SUPABASE_URL: ${{ secrets.NEXT_PUBLIC_SUPABASE_URL || 'https://placeholder.supabase.co' }}
          NEXT_PUBLIC_SUPABASE_ANON_KEY: ${{ secrets.NEXT_PUBLIC_SUPABASE_ANON_KEY || 'placeholder-anon-key' }}

      - name: Unit + Component Tests
        run: npx vitest run

      - name: Upload test results
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: test-results
          path: coverage/
          retention-days: 14
</file>

<file path=".husky/pre-commit">
#!/bin/sh

# Run unit tests (fast — ~300ms)
npx vitest run --reporter=dot 2>&1 | tail -5

# If tests fail, block the commit
if [ $? -ne 0 ]; then
    echo "❌ Unit tests failed. Fix before committing."
    exit 1
fi

echo "✅ All tests passed."
