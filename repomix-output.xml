 aria-hidden="true"
 />
 {isOfferable ?"Opening…" :"Opening…"}
 </>
 ) : isOfferable ? (
 <>💰 Make Offer</>
 ) : (
 <>
 <svg
 width="14"
 height="14"
 viewBox="0 0 24 24"
 fill="none"
 stroke="currentColor"
 strokeWidth="2"
 strokeLinecap="round"
 strokeLinejoin="round"
 aria-hidden="true"
 >
 <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
 </svg>
 Message Seller
 </>
 )}
 </button>
 {showOfferModal && (
 <MakeOfferModal
 horseId={horseId}
 horseName={horseName ||"This Horse"}
 sellerId={sellerId}
 askingPrice={askingPrice}
 onClose={() => setShowOfferModal(false)}
 />
 )}
 </>
 );
}
