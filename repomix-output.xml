 onChange={(e) => setReason(e.target.value)}
 rows={3}
 maxLength={2000}
 placeholder="Explain why this entry should be added. Include sources if available (e.g. 'Listed in the 2019 Breyer dealer catalog, page 12')."
 />
 <span
