 key={t}
 className="flex items-center gap-2 py-1"
 >
 <span className="text-[#22c55e]">✓</span>
 <span className="text-sm">{t}</span>
 </div>
 ))}
 </div>
 </div>
 )}
 </div>
 </div>
 </ExplorerLayout>
 );
}
