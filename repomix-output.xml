    ✅
   </span>
   <h2>Message Sent!</h2>
   <p>Thanks for reaching out. We&apos;ll get back to you as soon as possible.</p>
   </div>
  ) : (
   <form
   ref={formRef}
   action={formAction}
   className="mx-auto max-w-[560px]"
   id="contact-form"
