CREATE POLICY "replies_insert" ON group_post_replies FOR INSERT TO authenticated
  WITH CHECK ((SELECT auth.uid()) = user_id);

CREATE POLICY "replies_delete" ON group_post_replies FOR DELETE TO authenticated
