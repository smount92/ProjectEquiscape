 className="form-input"
 value={purchaseDate}
 onChange={(e) => setPurchaseDate(e.target.value)}
 />
 </div>
 </div>

 {/* Fuzzy Purchase Date */}
 <div className="mb-6">
 <label className="text-ink mb-1 block text-sm font-semibold">Approximate Purchase Date</label>
 <input
 className="form-input"
 type="text"
 value={purchaseDateText}
