 {notifs.map((n) => (
 <Link
 key={n.id}
 href={getNotifLink(n)}
 className={`border-stone-200 flex items-center gap-4 border-b px-6 py-4 text-inherit no-underline transition-colors hover:bg-black/[0.03] ${n.isRead ?"" :"bg-indigo-50/40"}`}
 onClick={() => handleClick(n.id)}
 >
