"use client";

import { useState } from "react";
import { reviewSuggestion } from "@/app/actions/suggestions";
import { useRouter } from "next/navigation";

interface Suggestion {
    id: string;
    suggestion_type: "mold" | "release" | "resin";
    name: string;
    details: string | null;
    submitted_by: string;
    status: string;
    created_at: string;
