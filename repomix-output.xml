 onChange={(e) => setPurchasePrice(e.target.value)}
 />
 </div>
 <div className="mb-6">
 <label htmlFor="edit-date" className="text-ink mb-1 block text-sm font-semibold">
 Purchase Date
 </label>
 <input
 id="edit-date"
