                ✅ Handled
            </div>
        );
    }

    const typeEmoji = suggestion.suggestion_type === "mold" ? "🐴"
        : suggestion.suggestion_type === "resin" ? "🎨" : "📋";

    return (
        <div className="card" style={{ padding: "var(--space-md)", marginBottom: "var(--space-md)" }}>
