 <label htmlFor="edit-insurance" className="text-ink mb-1 block text-sm font-semibold">
 Insurance Notes
 </label>
 <input
 id="edit-insurance"
 type="text"
 className="form-input"
 placeholder="Policy number, coverage details, etc."
